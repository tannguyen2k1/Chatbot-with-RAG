# Database Configuration
DATABASE_URL=postgresql://admin:admin123456@localhost:5432/fastapi_db

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# JWT Configuration
JWT_SECRET_KEY=NVT_CHATBOT_RAG
JWT_REFRESH_SECRET_KEY=NVT_CHATBOT_RAG_REFRESH
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_PATH=/
REFRESH_COOKIE_DOMAIN=

# CORS for web + Capacitor mobile
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,capacitor://localhost,ionic://localhost,https://vtms.localhost,null
CORS_ALLOW_ORIGIN_REGEX=^(null|https?://([a-zA-Z0-9-]+\.)?(localhost|127\.0\.0\.1|10\.0\.2\.2|192\.168\.\d+\.\d+)(:\d+)?|(capacitor|ionic|file)://.*)$

# Embedding Model
EMBEDDING_MODEL_NAME=AITeamVN/Vietnamese_Embedding
EMBEDDING_USE_FLASH_ATTENTION=false

# Reranker Model
RERANKER_MODEL_NAME=AITeamVN/Vietnamese_Reranker
RERANKER_MIN_TOKENS=20
RERANKER_MIN_CANDIDATES=3
CHUNK_MIN_TOKENS_TO_MERGE=40

# LLM
LLM_API_KEY=Yr6OyvgxyKb9RBpJ4eFPT2Hgz4bXUs6w
LLM_MODEL_NAME=mistral-large-latest
REFLECTION_ENABLED=true
