# Database Configuration
DATABASE_URL=postgresql://admin:admin123456@localhost:5432/fastapi_db

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET_KEY=your-super-secret-refresh-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10000000
REFRESH_TOKEN_EXPIRE_MINUTES=10000000


# REFRESH_COOKIE_SECURE=true
# REFRESH_COOKIE_SAMESITE=none

REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax

# CORS for web + Capacitor mobile
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost,capacitor://localhost,ionic://localhost,https://vtms.localhost,null
CORS_ALLOW_ORIGIN_REGEX=^(null|https?://([a-zA-Z0-9-]+\.)?(localhost|127\.0\.0\.1|10\.0\.2\.2|192\.168\.\d+\.\d+)(:\d+)?|(capacitor|ionic|file)://.*)$
