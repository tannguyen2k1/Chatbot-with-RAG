{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: FastAPI (uvicorn)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--reload",
                "--host", "0.0.0.0",
                "--port", "8000"
            ],
            "env": {
                "DATABASE_URL": "postgresql://admin:admin123456@localhost:5432/fastapi_db"
            },
            "jinja": true,
            "cwd": "${workspaceFolder}/backend"
        }
    ]
}